JWT_SECRET=change-this-to-a-long-random-string
PORT=4000

# Optional — powers richer chatbot replies via the Anthropic API. Leave blank
# and the chatbot still works, using a built-in rule-based assistant that
# reads real order/product data straight from the database.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
